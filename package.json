{
  "name": "FluxRoute",
  "private": true,
  "workspaces": [
    "packages/*",
    "apps/*"
  ],
  "scripts": {
    "dev:api": "npm run dev -w @fluxroute/api",
    "dev:dashboard": "npm run dev -w @fluxroute/dashboard",
    "dev:mcp": "npm run dev -w @fluxroute/mcp-server",
    "build": "npm run build --workspaces --if-present",
    "build:packages": "npm run build -w @fluxroute/shared && npm run build -w @fluxroute/database && npm run build -w @fluxroute/provider-sdk",
    "lint": "npm run lint --workspaces --if-present",
    "typecheck": "npm run typecheck --workspaces --if-present",
    "migrate": "npm run migrate -w @fluxroute/database",
    "seed": "npm run seed -w @fluxroute/database",
    "security:audit": "npm audit --audit-level=high",
    "pretest": "npm run build:packages",
    "test": "vitest run"
  },
  "devDependencies": {
    "vitest": "^1.6.1"
  }
}
