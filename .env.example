# ============================================================
# FluxRoute - environment variables
# Copy to `.env.local` and fill in values. Never commit secrets.
# ============================================================

# ---------- Database & cache ----------
# PostgreSQL 15+ connection string.
DATABASE_URL=postgresql://FluxRoute:FluxRoute@localhost:5432/FluxRoute
# Redis 7+ connection string (payment status cache, rate limiting).
REDIS_URL=redis://localhost:6379

# ---------- Auth (JWT RS256) ----------
# Provide key file paths OR inline PEM via JWT_PRIVATE_KEY / JWT_PUBLIC_KEY.
# Generate: openssl genrsa -out keys/private.pem 2048
#           openssl rsa -in keys/private.pem -pubout -out keys/public.pem
JWT_PRIVATE_KEY_PATH=./keys/private.pem
JWT_PUBLIC_KEY_PATH=./keys/public.pem
# JWT_PRIVATE_KEY=
# JWT_PUBLIC_KEY=
JWT_ISSUER=fluxroute.io
JWT_EXPIRY=1h

# ---------- Solana ----------
# Public RPC is rate-limited; use a production-grade RPC endpoint for live use.
SOLANA_RPC_URL=https://api.mainnet-beta.solana.com
SOLANA_NETWORK=mainnet-beta
# SPL mint used to verify USDC-SPL payments on the configured network.
# Mainnet USDC default below; override for devnet.
USDC_MINT=EPjFWdd5AufqSSqeM2qN1xzybapC8G4wEGGkZwyTDt1v

# ---------- API ----------
API_PORT=4000
# Comma-separated list of browser origins allowed to call the API.
# Leave empty only for server-to-server/local non-browser usage.
CORS_ORIGIN=http://localhost:3000
# Upstream provider request timeout (ms) used by the payment /execute proxy.
PROXY_TIMEOUT_MS=15000
# Maximum JSON payload size forwarded to a provider during /execute.
MAX_PROVIDER_PAYLOAD_BYTES=65536
# Development only: set true to allow http:// provider base URLs.
ALLOW_INSECURE_PROVIDER_URLS=false

# ---------- MCP server (AI agent client) ----------
MCP_PORT=3001
# API key minted via POST /api/auth/api-keys after registering.
FLUXROUTE_API_KEY=fr_live_your_key_here
FLUXROUTE_API_URL=http://localhost:4000
FLUXROUTE_WALLET_MODE=managed

# ---------- Frontends (Next.js) ----------
# Dashboard (apps/dashboard) and landing (fluxroute-landing).
NEXT_PUBLIC_API_URL=http://localhost:4000
NEXT_PUBLIC_SITE_URL=http://localhost:3000
